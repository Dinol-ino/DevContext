# Local development backend origin. The frontend app appends /api/v1 automatically.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Set these for Supabase-backed authentication in local or production environments.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production note:
# For a deployed frontend, set VITE_API_BASE_URL to the backend origin only.
# Example: https://devcontext-backend-agents.onrender.com
